# Demo mode works without any credentials.
NEXT_PUBLIC_AI_PROVIDER=demo

# Optional future server-side provider configuration. Never expose these with
# a NEXT_PUBLIC_ prefix or enter production secrets in the browser UI.
OPENAI_API_KEY=
OPENAI_MODEL=

# Optional future repository connector configuration.
GITHUB_APP_ID=
GITHUB_PRIVATE_KEY=
GITHUB_WEBHOOK_SECRET=
