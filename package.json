{
  "name": "escalation-engineer",
  "version": "0.1.0",
  "private": true,
  "description": "Repository-aware customer escalation to engineering ticket workflow.",
  "engines": {
    "node": ">=22.13.0"
  },
  "scripts": {
    "dev": "vinext dev",
    "build": "vinext build",
    "start": "vinext start",
    "format": "prettier --check .",
    "format:write": "prettier --write .",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --ignore-pattern dist --ignore-pattern .next --ignore-pattern .vinext",
    "test": "tsx --test tests/auth.test.ts tests/ticket-generation.test.ts tests/workflow.test.ts",
    "validate": "npm run format && npm run typecheck && npm run lint && npm run test && npm run build"
  },
  "dependencies": {
    "next": "16.2.6",
    "react": "19.2.6",
    "react-dom": "19.2.6"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "1.37.1",
    "@types/node": "22.19.19",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.2",
    "@vitejs/plugin-rsc": "0.5.26",
    "eslint": "9.39.4",
    "eslint-config-next": "16.2.6",
    "prettier": "3.6.2",
    "react-server-dom-webpack": "19.2.6",
    "tsx": "4.20.5",
    "typescript": "5.9.3",
    "vinext": "0.0.50",
    "vite": "8.0.13",
    "wrangler": "4.92.0"
  },
  "type": "module"
}
